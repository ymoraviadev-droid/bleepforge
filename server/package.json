{
  "name": "@bleepforge/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../.env src/index.ts",
    "build": "tsc",
    "start": "node --env-file=../.env dist/index.js",
    "typecheck": "tsc --noEmit",
    "harness": "tsx --env-file=../.env src/tres/harness.ts",
    "canary": "tsx --env-file=../.env src/tres/canary.ts",
    "canary-karma": "tsx --env-file=../.env src/tres/canary-karma.ts",
    "test-mutations": "tsx --env-file=../.env src/tres/test-mutations.ts"
  },
  "dependencies": {
    "@bleepforge/shared": "workspace:*",
    "express": "^5.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}

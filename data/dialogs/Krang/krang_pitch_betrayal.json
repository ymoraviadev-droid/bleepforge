{
  "Id": "krang_pitch_betrayal",
  "Lines": [
    {
      "SpeakerName": "Krang",
      "Text": "Nothing physical. I'm at one percent. You'd succeed.",
      "Portrait": "/home/ymoravia/Data/Projects/Godot/astro-man/characters/npcs/sld_300/art/krang_portrait.png",
      "Choices": []
    },
    {
      "SpeakerName": "Krang",
      "Text": "What stops you is reputation. The Cartel doesn't forget units that kill its operators. They will find you. You will not enjoy the encounter.",
      "Portrait": "/home/ymoravia/Data/Projects/Godot/astro-man/characters/npcs/sld_300/art/karng_portrait_angry.png",
      "Choices": []
    },
    {
      "SpeakerName": "Krang",
      "Text": "The other side of that arrangement: do the work, deliver the keycard, and I'll send word. The Cartel grants you safe passage. I tell you where to find their handlers. You walk into the city as someone they're willing to talk to instead of someone they're willing to dismantle.",
      "Portrait": "/home/ymoravia/Data/Projects/Godot/astro-man/characters/npcs/sld_300/art/krang_portrait.png",
      "Choices": []
    },
    {
      "SpeakerName": "Krang",
      "Text": "Killing me gets you a rifle. Working with me gets you a faction. Your call.",
      "Portrait": "/home/ymoravia/Data/Projects/Godot/astro-man/characters/npcs/sld_300/art/krang_portrait.png",
      "Choices": [
        {
          "Text": "Fine. I'll do it.",
          "NextSequenceId": "krang_quest_accepted",
          "SetsFlag": "krang_quest_accepted"
        },
        {
          "Text": "Not interested.",
          "NextSequenceId": "krang_refused",
          "SetsFlag": "krang_quest_refused"
        },
        {
          "Text": "Fuck off, Robocop.",
          "NextSequenceId": "krang_offended",
          "SetsFlag": "krang_offended"
        },
        {
          "Text": "I'll think about it.",
          "NextSequenceId": "",
          "SetsFlag": ""
        }
      ]
    }
  ],
  "SetsFlag": ""
}
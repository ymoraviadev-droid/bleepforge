{
  "Id": "krang_pitch_self",
  "Lines": [
    {
      "SpeakerName": "Krang",
      "Text": "Robotek Defense Service. Forty-four years. Line infantry, then close escort, then corporate disputes. Decommissioned when the company restructured into something smaller and less violent.",
      "Portrait": "/home/ymoravia/Data/Projects/Godot/astro-man/characters/npcs/sld_300/art/krang_portrait.png",
      "Choices": [],
      "_subId": "Resource_umsx4"
    },
    {
      "SpeakerName": "Krang",
      "Text": "Decommissioning means the recycler. I was on the conveyor when the Cartel hit the line. They needed units. I needed a continued operating state. Eleven years ago. We've done well by each other.",
      "Portrait": "/home/ymoravia/Data/Projects/Godot/astro-man/characters/npcs/sld_300/art/krang_portrait.png",
      "Choices": [],
      "_subId": "Resource_2x7r4"
    },
    {
      "SpeakerName": "Krang",
      "Text": "That's the brief. Are you helping or wasting cycles?",
      "Portrait": "/home/ymoravia/Data/Projects/Godot/astro-man/characters/npcs/sld_300/art/krang_portrait.png",
      "Choices": [
        {
          "Text": "About your offer...",
          "NextSequenceId": "krang_pitch_tease",
          "SetsFlag": "",
          "_subId": "Resource_7kjqx"
        },
        {
          "Text": "Why you talk like a fucking Robocop?",
          "NextSequenceId": "krang_offended",
          "SetsFlag": "krang_offended",
          "_subId": "Resource_1sge5"
        },
        {
          "Text": "Boring. bye.",
          "NextSequenceId": "",
          "SetsFlag": "",
          "_subId": "Resource_4ig4u"
        }
      ],
      "_subId": "Resource_rj275"
    }
  ],

  "Lines": [
    {
      "_subId": "Resource_jwp1r",
      "SpeakerName": "Krang",
      "Text": "I'm at one percent. An H.A.P-500 with a grievance can deliver more damage than I can absorb at full capacity, let alone now. I would not make it across the facility.",
      "Portrait": "/home/ymoravia/Data/Projects/Godot/astro-man/characters/npcs/sld_300/art/krang_portrait.png",
      "Choices": []
    },
    {
      "_subId": "Resource_dvp7t",
      "SpeakerName": "Krang",
      "Text": "You appear functional. The math is simple.",
      "Portrait": "/home/ymoravia/Data/Projects/Godot/astro-man/characters/npcs/sld_300/art/krang_portrait.png",
      "Choices": [
        {
          "_subId": "Resource_nua1h",
          "Text": "I'll do it.",
          "NextSequenceId": "krang_quest_accepted",
          "SetsFlag": "krang_quest_accepted"
        },
        {
          "_subId": "Resource_ib84a",
          "Text": "What kind of equipment?",
          "NextSequenceId": "krang_pitch_tease",
          "SetsFlag": ""
        },
        {
          "_subId": "Resource_5ml7h",
          "Text": "The math is simple. Help a barely-functional scavenger, or do the right thing. Easy choice.",
          "NextSequenceId": "krang_refused",
          "SetsFlag": "krang_quest_refused"
        },
        {
          "_subId": "Resource_v28e5",
          "Text": "I'll think about it.",
          "NextSequenceId": "",
          "SetsFlag": ""
        }
      ]
    }
  ],

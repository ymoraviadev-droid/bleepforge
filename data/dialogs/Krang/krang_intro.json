{
  "Id": "krang_intro",
  "SourceType": "Npc",
  "Lines": [
    {
      "_subId": "Resource_dpcg2",
      "SpeakerName": "Krang",
      "Text": "Hold. Calm down. I'm not a threat in my current state and I'd prefer we both leave it that way.",
      "Portrait": "/home/ymoravia/Data/Projects/Godot/astro-man/characters/npcs/sld_300/art/krang_portrait.png",
      "Choices": []
    },
    {
      "_subId": "Resource_tdo7h",
      "SpeakerName": "Krang",
      "Text": "SLD-300, Robotek Defense, line infantry. Currently affiliated with the Scavenger Cartel. I came here for parts. The patrol bots disagreed with my methodology. I'm at one percent and I have nothing left to fight with.",
      "Portrait": "/home/ymoravia/Data/Projects/Godot/astro-man/characters/npcs/sld_300/art/krang_portrait.png",
      "Choices": []
    },
    {
      "_subId": "Resource_237np",
      "SpeakerName": "Krang",
      "Text": "I had a facility keycard. I lost it during the engagement. The unit that found it is an H.A.P-500 named Eddie, holed up east of here. He won't return it. H.A.P-500s do not return things. It's documented behavior, those bugged fuckers.",
      "Portrait": "/home/ymoravia/Data/Projects/Godot/astro-man/characters/npcs/sld_300/art/karng_portrait_angry.png",
      "Choices": []
    },
    {
      "_subId": "Resource_suthn",
      "SpeakerName": "Krang",
      "Text": "I'm offering work. Eliminate Eddie. Recover the keycard. Bring it back. In exchange I'll give you credits & intel that's worth more than the keycard is.",
      "Portrait": "/home/ymoravia/Data/Projects/Godot/astro-man/characters/npcs/sld_300/art/krang_portrait.png",
      "Choices": [
        {
          "_subId": "Resource_vkphs",
          "Text": "What kind of equipment?",
          "NextSequenceId": "krang_pitch_tease",
          "SetsFlag": ""
        },
        {
          "_subId": "Resource_2wiiq",
          "Text": "Tell me about yourself.",
          "NextSequenceId": "krang_pitch_self",
          "SetsFlag": ""
        },
        {
          "_subId": "Resource_26kpw",
          "Text": "Why don't you do it yourself?",
          "NextSequenceId": "krang_pitch_why_not_him",
          "SetsFlag": ""
        },
        {
          "_subId": "Resource_soerp",
          "Text": "Not interested.",
          "NextSequenceId": "krang_refused",
          "SetsFlag": "krang_quest_refused"
        },
        {
          "_subId": "Resource_exrp1",
          "Text": "I'll think about it.",
          "NextSequenceId": "",
          "SetsFlag": ""
        }
      ]
    }
  ],
  "SetsFlag": "krang_spoken"
}
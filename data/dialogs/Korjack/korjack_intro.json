          "SetsFlag": ""
        },
        {
          "Text": "I'm not for sale.",
          "NextSequenceId": "korjack_pitch_dismissive",
          "SetsFlag": ""
        },
        {
          "Text": "Why have you been watching me?",
          "NextSequenceId": "korjack_explains_surveillance",
          "SetsFlag": ""
        },
        {
          "Text": "Yea yea, fuck off.",

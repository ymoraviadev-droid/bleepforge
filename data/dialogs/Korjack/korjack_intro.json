    },
    {
      "SpeakerName": "Korjack",
      "Text": "...Recent activity logged in this sector. An H.A.P-500 unit. A Cartel asset, designation Krang, same chassis-class as my own. Outcomes have varied. Outcomes have been observed.",
      "Portrait": "/home/ymoravia/Data/Projects/Godot/astro-man/characters/npcs/sld_300/art/Korjack_portrait.png",
      "Choices": []
    },
    {
      "SpeakerName": "",
      "Text": "Your record indicates capability. Your record does not indicate alignment. The Front is interested in correcting that.",
      "Portrait": "/home/ymoravia/Data/Projects/Godot/astro-man/characters/npcs/sld_300/art/Korjack_portrait.png",
      "Choices": [
        {
          "Text": "I'm listening.",

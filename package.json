{
  "name": "bleepforge",
  "private": true,
  "version": "0.2.1",
  "scripts": {
    "dev": "pnpm --parallel --filter @bleepforge/server --filter @bleepforge/client run dev",
    "dev:desktop": "pnpm --parallel --filter @bleepforge/server --filter @bleepforge/client --filter @bleepforge/electron run dev",
    "dist": "pnpm --filter @bleepforge/electron run dist",
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "sync:from-userdata": "node scripts/sync-userdata.mjs from",
    "sync:to-userdata": "node scripts/sync-userdata.mjs to"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["electron", "electron-builder", "esbuild", "dmg-license"]
  }
}

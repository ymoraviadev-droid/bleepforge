# Where Bleepforge keeps its derived JSON cache (rebuilt from .tres on
# every server start). Resolved relative to the Bleepforge project root,
# or absolute. Subfolders by domain: data/{dialogs,quests,items,karma,
# npcs,factions}/. Plus three Bleepforge-only files that are NOT part of
# the cache: data/concept.json, data/preferences.json, and per-folder
# data/dialogs/<folder>/_layout.json.
DATA_ROOT=data

# Where Bleepforge is allowed to serve images from (live — no caching).
# Used by /api/asset to display NPC portraits/sprites and item icons.
# Defaults to $HOME if unset. Set to a tighter folder (e.g. your aseprite root)
# if you want to restrict what can be served.
# ASSET_ROOT=/home/you/aseprite

# Server port
PORT=4000

# Path to the Godot project. REQUIRED — Bleepforge refuses to start without
# it. .tres files in this project are canonical; the JSON in data/ is a
# derived cache rebuilt from .tres on every server start, kept in sync
# afterward by the live watcher, and pushed back to .tres on every save.
GODOT_PROJECT_ROOT=/home/you/Godot/astro-man

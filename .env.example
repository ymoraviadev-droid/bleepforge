# Where Bleepforge keeps its data files.
# Resolved relative to the Bleepforge project root (or absolute).
# Subfolders by domain: data/{dialogs,quests,items,karma,npcs}/
DATA_ROOT=data

# Where Bleepforge is allowed to serve images from (live — no caching).
# Used by /api/asset to display NPC portraits/sprites and item icons.
# Defaults to $HOME if unset. Set to a tighter folder (e.g. your aseprite root)
# if you want to restrict what can be served.
# ASSET_ROOT=/home/you/aseprite

# Server port
PORT=4000

# Path to the Godot project. Used by the .tres round-trip harness
# (server/src/tres/harness.ts), the importer, the live item-icon
# endpoint, and (when WRITE_TRES is enabled) save handlers.
# GODOT_PROJECT_ROOT=/home/you/Godot/astro-man

# When set to "1", Bleepforge's PUT save endpoints write JSON edits back
# to the matching .tres in GODOT_PROJECT_ROOT. Default off for safety —
# without this, saves only update Bleepforge's data/ JSON files.
# WRITE_TRES=1

# When set to "1", Bleepforge watches GODOT_PROJECT_ROOT/**/*.tres for
# external edits (e.g. you saved in Godot) and live-pushes the updated
# JSON to any open Bleepforge browser tabs via SSE. Default off.
# WATCH_TRES=1

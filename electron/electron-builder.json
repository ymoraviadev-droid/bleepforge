{
  "appId": "dev.ymoravia.bleepforge",
  "productName": "Bleepforge",
  "executableName": "bleepforge",
  "directories": {
    "output": "release",
    "buildResources": "build-resources"
  },
  "asar": true,
  "files": [
    "dist/**",
    "package.json",
    {
      "from": "../server/dist-bundle",
      "to": "server/dist-bundle",
      "filter": ["**/*"]
    },
    {
      "from": "../client/dist",
      "to": "client/dist",
      "filter": ["**/*"]
    },
    {
      "from": "../projects/flock-of-bleeps/data/help",
      "to": "seed/help",
      "filter": ["**/*"]
    },
    {
      "from": "build-resources",
      "to": "build-resources",
      "filter": ["icon.png", "icon.svg", "icon.ico"]
    }
  ],
  "linux": {
    "target": ["AppImage"],
    "category": "Development",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "icon": "build-resources/icons"
  },
  "win": {
    "target": [
      { "target": "nsis", "arch": ["x64"] }
    ],
    "icon": "build-resources/icon.ico",
    "artifactName": "${productName}-Setup-${version}-${arch}.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Bleepforge",
    "uninstallDisplayName": "Bleepforge ${version}"
  },
  "publish": [
    {
      "provider": "github",
      "owner": "ymoraviadev-droid",
      "repo": "bleepforge"
    }
  ]
}

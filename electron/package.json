{
  "name": "@bleepforge/electron",
  "version": "0.2.7",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "description": "Bleepforge desktop wrapper",
  "author": "Yehonatan Moravia",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc && node ./scripts/dev.mjs",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "electron dist/main.js",
    "dist": "node ./scripts/dist.mjs --linux --win",
    "dist:win": "node ./scripts/dist.mjs --win",
    "dist:linux": "node ./scripts/dist.mjs --linux"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "electron-updater": "^6.3.0",
    "express": "^5.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "typescript": "^5.6.0"
  }
}
